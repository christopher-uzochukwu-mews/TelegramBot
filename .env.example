# Get from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: for AI briefings on assignments (get from https://platform.openai.com/api-keys)
# ChatGPT Pro does NOT include API access - add payment at platform.openai.com to use this
OPENAI_API_KEY=

# Optional: set if you want only one user to receive reminders (chat_id from /chatid)
# Leave empty to allow any user who /start to receive reminders
ALLOWED_CHAT_IDS=

# Optional: when to send the daily reminder (Docker uses TZ=America/Vancouver, so 20:00 = 8pm Vancouver/BC)
REMINDER_HOUR=20
REMINDER_MINUTE=0

# Optional: port for health check endpoint (GET /health). Default 8080
HEALTH_CHECK_PORT=8080
